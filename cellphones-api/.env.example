APP_NAME=Cellphones
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://cellphones-api.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=debug

# =============================
# Database (Use SQLite for Render)
# =============================
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite
DB_FOREIGN_KEYS=true

# =============================
# Cache & Session
# =============================
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=cellphone-two.vercel.app
SESSION_PATH=/

# =============================
# Redis (optional)
# =============================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================
# Mail (disabled in production)
# =============================
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@cellphones.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================
# Sanctum Auth
# =============================
SANCTUM_STATEFUL_DOMAINS=cellphone-two.vercel.app
SESSION_SECURE_COOKIE=true

# =============================
# App workers
# =============================
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# =============================
# Render port
# =============================
PORT=10000
